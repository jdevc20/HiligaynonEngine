          "host": ["{{baseUrl}}"],
          "path": ["sentences"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "50" },
            { "key": "search", "value": "" }
          ]
        }
      }
    },
    {
      "name": "Get Sentence By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
