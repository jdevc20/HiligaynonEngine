        "body": {
          "mode": "raw",
          "raw": "{\n  \"english\": \"Good morning\",\n  \"hiligaynon\": \"Maayong aga\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sentences",
          "host": ["{{baseUrl}}"],
          "path": ["sentences"]
        }
